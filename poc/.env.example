# ─────────────────────────────────────────────────────────────
# Project BlueLine POC — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── OPTION 1: Azure OpenAI (RECOMMENDED for company laptops) ──
# Data stays inside your company's Azure tenant. Ask your Azure
# admin for the endpoint, key, and deployment name.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── OPTION 2: Anthropic Claude (only if Azure OpenAI not available) ──
# NOTE: This sends data to Anthropic's external servers.
# Only use if your company allows it.
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────────────────────────
# Azure DevOps — Live PR Review integration
# Get your PAT: Azure DevOps → User Settings → Personal Access Tokens
# Required PAT scopes: Code (Read) + Pull Request Threads (Read & Write)
# ─────────────────────────────────────────────────────────────
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org-name
AZURE_DEVOPS_PAT=your-personal-access-token-here
AZURE_DEVOPS_PROJECT=YourProjectName
AZURE_DEVOPS_REPO=YourRepoName
